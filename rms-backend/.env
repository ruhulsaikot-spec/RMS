# ============================================================
# Reimbursement Management System (RMS) - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ── Application ──────────────────────────────────────────────
APP_NAME=RMS Backend
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_PREFIX=/api
APP_DOCS_URL=/docs
APP_REDOC_URL=/redoc

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rms_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=rms_database
POSTGRES_SCHEMA=public
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_RECYCLE=3600
POSTGRES_POOL_PRE_PING=true
POSTGRES_ECHO=false
POSTGRES_CONNECT_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DECODE_RESPONSES=true
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=rms-enterprise
JWT_AUDIENCE=rms-users

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE_ENABLED=false
LOG_FILE_PATH=logs/rms-backend.log
LOG_FILE_MAX_SIZE_MB=50
LOG_FILE_BACKUP_COUNT=10

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── File Upload ──────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.xlsx,.docx
UPLOAD_STORAGE_PATH=uploads

# ── Email (Optional) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@rms-enterprise.com
SMTP_FROM_NAME=RMS System

# ── Docker Compose Override ──────────────────────────────────
COMPOSE_PROJECT_NAME=rms
